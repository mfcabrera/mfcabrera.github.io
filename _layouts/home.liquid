---
layout: default
---
<div class="post rb-home">
  <header class="rb-home-hero">
    <div class="rb-eyebrow rb-eyebrow--muted">
      {{ site.first_name }}
      {{ site.last_name }} · {{ page.location | default: 'Berlin' }}
    </div>
    <h1 class="rb-home-name">
      {{ page.subtitle | default: site.description }}
    </h1>
    {% if page.about %}
      <div class="rb-home-bio">{{ page.about | markdownify }}</div>
    {% endif %}
    {% if content != '' %}
      <div class="rb-home-bio">{{ content }}</div>
    {% endif %}
  </header>

  {% comment %} ── Section 01 · Writing ────────────────────────────────────── {% endcomment %}
  {% assign latest_posts = site.posts | slice: 0, 5 %}
  {% if latest_posts.size > 0 %}
    <section class="rb-home-section">
      <div class="rb-home-section__head">
        <span class="rb-figure rb-figure--accent rb-home-section__num">01</span>
        <span class="rb-home-section__label">Writing</span>
        <a class="rb-home-section__more" href="{{ '/blog/' | relative_url }}">All posts &rarr;</a>
      </div>
      <div class="rb-home-section__body">
        {% for post in latest_posts %}
          {% if post.external_source == blank %}
            {% assign read_time = post.content | number_of_words | divided_by: 180 | plus: 1 %}
          {% else %}
            {% assign read_time = post.feed_content | strip_html | number_of_words | divided_by: 180 | plus: 1 %}
          {% endif %}
          {% assign year = post.date | date: '%Y' %}

          {% if post.redirect == blank %}
            {% assign post_url = post.url | relative_url %}
            {% assign post_target = '' %}
          {% elsif post.redirect contains '://' %}
            {% assign post_url = post.redirect %}
            {% assign post_target = '_blank' %}
          {% else %}
            {% assign post_url = post.redirect | relative_url %}
            {% assign post_target = '' %}
          {% endif %}

          <a
            class="rb-numrow"
            href="{{ post_url }}"
            {% if post_target == '_blank' %}
              target="_blank" rel="noopener"
            {% endif %}
          >
            <span class="rb-numrow__n">{{ year }}</span>
            <span>
              <span class="rb-numrow__title">{{ post.title }}</span>
              {% if post.description %}
                <span class="rb-numrow__sub">{{ post.description }}</span>
              {% endif %}
            </span>
            <span class="rb-numrow__meta">
              {% if post.external_source %}{{ post.external_source }} · {% endif -%}
              {{- read_time }} min
            </span>
          </a>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% comment %} ── Section 02 · Talks (latest 3) ──────────────────────────── {% endcomment %}
  {% if site.data.talks %}
    {% assign latest_talks = site.data.talks | slice: 0, 3 %}
    <section class="rb-home-section">
      <div class="rb-home-section__head">
        <span class="rb-figure rb-figure--accent rb-home-section__num">02</span>
        <span class="rb-home-section__label">Talks</span>
        <a class="rb-home-section__more" href="{{ '/talks/' | relative_url }}">All talks &rarr;</a>
      </div>
      <div class="rb-home-section__body">
        {% for talk in latest_talks %}
          {% if talk.url %}
            <a class="rb-numrow" href="{{ talk.url }}" target="_blank" rel="noopener">
          {% else %}
            <div class="rb-numrow">
          {% endif %}
          <span class="rb-numrow__n">{{ talk.year }}</span>
          <span>
            <span class="rb-numrow__title">{{ talk.title }}</span>
            {% if talk.venue %}
              <span class="rb-numrow__sub">
                {{- talk.venue -}}
                {%- if talk.format %} · {{ talk.format }}{% endif -%}
              </span>
            {% elsif talk.format %}
              <span class="rb-numrow__sub">{{ talk.format }}</span>
            {% endif %}
          </span>
          <span class="rb-numrow__meta">
            {%- if talk.url %}Slides &rarr;{% endif -%}
          </span>
          {% if talk.url %}</a>{% else %}</div>{% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% comment %} ── Section 03 · Code ──────────────────────────────────────── {% endcomment %}
  {% if site.data.repositories.repos %}
    <section class="rb-home-section">
      <div class="rb-home-section__head">
        <span class="rb-figure rb-figure--accent rb-home-section__num">03</span>
        <span class="rb-home-section__label">Code</span>
        <a class="rb-home-section__more" href="https://github.com/{{ site.data.repositories.github_user }}" target="_blank" rel="noopener"
          >All repositories &rarr;</a
        >
      </div>
      <div class="rb-home-section__body">
        {% for repo in site.data.repositories.repos %}
          <a class="rb-numrow rb-numrow--repo" href="{{ repo.url }}" target="_blank" rel="noopener">
            <span class="rb-numrow__n rb-numrow__n--mono">/{{ repo.name }}</span>
            <span>
              <span class="rb-numrow__title">{{ repo.name }}</span>
              {% if repo.description %}
                <span class="rb-numrow__sub">{{ repo.description }}</span>
              {% endif %}
            </span>
            <span class="rb-numrow__meta">{{ repo.lang }}</span>
          </a>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if page.social %}
    <footer class="rb-home-social">
      <div class="rb-eyebrow rb-eyebrow--muted">Find me</div>
      <div class="contact-icons">{% social_links %}</div>
    </footer>
  {% endif %}
</div>
